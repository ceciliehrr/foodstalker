{
  "name": "@example/basics",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "scripts": {
    "dev": "bash scripts/with-nvm.sh astro dev",
    "dev:with-data": "bash scripts/with-nvm.sh node scripts/dev-with-data.js",
    "host": "bash scripts/with-nvm.sh astro dev --host",
    "start": "bash scripts/with-nvm.sh astro dev",
    "prebuild": "bash scripts/with-nvm.sh node scripts/fetch-notion-data.js",
    "build": "bash scripts/with-nvm.sh astro build",
    "preview": "bash scripts/with-nvm.sh astro preview",
    "fetch-data": "bash scripts/with-nvm.sh node scripts/fetch-notion-data.js",
    "proxy": "mkcert -install && mkcert localhost && local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem"
  },
  "devDependencies": {
    "@astrojs/vue": "^6.0.1",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "astro": "^6.2.1",
    "leaflet": "^1.9.4",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vue": "^3.5.33"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.8",
    "@netlify/plugin-csp-nonce": "^1.6.2",
    "@notionhq/client": "^2.3.0",
    "@takuma-ru/vue-swipe-modal": "^5.0.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "fs-extra": "^11.3.4",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.10"
  }
}
